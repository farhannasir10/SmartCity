# Optional — Planning assistant (pick one; Groq is free-tier friendly)
# https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# If you see 413 / TPM too large, the app sends a compact context; shorten chat history or try a larger-context model on Groq.

